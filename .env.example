# ProBasket POS Environment Variables Template
# Copy this file to a new file named `.env` in the same directory and fill in your Supabase credentials.

# Your Supabase API Project URL (found in project Settings -> API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase Anon Public API Key (found in project Settings -> API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
